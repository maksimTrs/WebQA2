# Required for running tests against the real application
TEST_USER_EMAIL=your-test-email@example.com
TEST_PASSWORD=your-test-password

# WireMock (used by docker-compose for WireMock service)
WIREMOCK_PORT=9999

# Optional overrides
APP_BASE_URL=https://webqa.mercdev.com
WEBDRIVER_BROWSER=chrome
SELENIUM_GRID_URL=http://localhost:4444/wd/hub
